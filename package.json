{
	"name": "@e280/hottie",
	"version": "0.1.0-1",
	"description": "⚡ hot-reloading http server",
	"license": "MIT",
	"author": "Chase Moskal <chasemoskal@gmail.com>",
	"type": "module",
	"sideEffects": false,
	"files": [
		"x",
		"s"
	],
	"bin": {
		"hottie": "x/cli.js"
	},
	"scripts": {
		"build": "rm -rf x && mkdir x && tsc && cp s/index.html x/index.html && chmod 665 x/index.html",
		"test": "exit 0",
		"start": "node x/cli.js",
		"count": "find s -path '*/_archive' -prune -o -name '*.ts' -exec wc -l {} +"
	},
	"dependencies": {
		"@benev/argv": "^0.3.14",
		"@e280/stz": "^0.2.24",
		"chokidar": "^5.0.0",
		"http-proxy-3": "^1.23.2",
		"sirv": "^3.0.2",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"@types/ws": "^8.18.1",
		"typescript": "^5.9.3"
	},
	"keywords": [
		"http server",
		"dev server",
		"hot reload",
		"hot reloading"
	],
	"homepage": "https://github.com/e280/hottie#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/e280/hottie.git"
	},
	"bugs": {
		"url": "https://github.com/e280/hottie/issues"
	}
}
